// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String
  passwordHash      String
  walletAddress     String?  @unique
  trustScore  Int      @default(0)
  level             Int      @default(1)
  creditLine        Float    @default(10000)
  interestRate      Float    @default(4.0)
  outstandingBalance Float   @default(0)
  warningsCount     Int      @default(0)
  rewardPoints      Int      @default(0)
  joinedDate        DateTime @default(now())
  lastLogin         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  payments          Payment[]
  redeemedRewards   RedeemedReward[]
  authTokens        AuthToken[]

  @@map("users")
}

model AuthToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_tokens")
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  type        String   // 'on-time', 'late', 'early'
  description String
  transactionHash String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Reward {
  id          String   @id @default(cuid())
  partner     String
  title       String
  description String
  minScore    Int
  minPoints   Int      @default(0)
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  redeemedRewards RedeemedReward[]

  @@map("rewards")
}

model RedeemedReward {
  id          String   @id @default(cuid())
  userId      String
  rewardId    String
  pointsUsed  Int
  status      String   @default("pending") // 'pending', 'confirmed', 'expired'
  redemptionCode String?
  createdAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@unique([userId, rewardId])
  @@map("redeemed_rewards")
}

model LevelConfig {
  id       Int @id @default(autoincrement())
  level    Int @unique
  name     String
  minScore Int
  maxScore Int
  perks    String // JSON string array
  color    String
  interestRate Float

  @@map("level_configs")
}